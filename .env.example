# =================================================================================
# FARMLINK AI - SMART AGRICULTURE MARKETPLACE
# Environment Variable Template Configuration
# Copy this file to '.env.local' and populate with production credentials.
# =================================================================================

# 1. DATABASE CONFIGURATION (Supabase PostgreSQL Connection URI)
# Replace [PASSWORD] and [PROJECT_REF] with your Supabase DB credentials
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?schema=public"

# 2. NEXTAUTH CREDENTIALS CONFIGURATION
# Generate a secure 32-character random string (e.g. using openssl rand -base64 32)
NEXTAUTH_SECRET="your-nextauth-secret-hash-here"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 3. WEBSOCKET CONTROLLERS CONFIGURATION
# Deployed URL of the socket-server.js microservice
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"

# 4. GOOGLE GEMINI AI API KEY
# Obtain this from the Google AI Studio console
GEMINI_API_KEY="AIzaSy...your-gemini-key"

# 5. FINTECH PAYMENTS CONFIGURATION (Razorpay India gateway credentials)
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_SECRET="your-razorpay-key-secret"
RAZORPAY_WEBHOOK_SECRET="your-webhook-event-signature-secret"
